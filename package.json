{
  "name": "file-size-vscode",
  "displayName": "file size vscode",
  "description": "文件大小显示",
  "version": "0.0.5",
  "publisher": "ZhengWei513",
  "author": {
    "name": "ZhengWei513"
  },
  "keywords": [
    "file size",
    "file size vscode",
    "file message"
  ],
  "engines": {
    "vscode": "^1.77.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [],
    "configuration": {
      "title": "file size vscode",
      "properties": {
        "fileSizeVscode.alignment": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "enumDescriptions": [
            "状态栏左侧",
            "状态栏右侧"
          ],
          "default": "right",
          "description": "在状态栏显示位置"
        },
        "fileSizeVscode.priority": {
          "type": "number",
          "description": "在状态栏显示位置优先级(数值越大越靠右/左)",
          "default": 0
        }
      }
    }
  },
  "icon": "./images/icon.png",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/j787701730/file-size-vscode"
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "@types/vscode": "^1.77.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.1",
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  }
}
